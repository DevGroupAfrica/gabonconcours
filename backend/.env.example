# Serveur
PORT=8002
NODE_ENV=development
FRONTEND_URL=http://localhost:8001

# Base de données
# Une URL MySQL complète prend priorité sur les variables DB_*.
# Exemple : mysql://utilisateur:mot_de_passe@hote:3306/nom_de_la_base
DATABASE_URL=
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gabconcours

# SingPay - à récupérer depuis SingPay Workspace
SINGPAY_BASE_URL=https://gateway.singpay.ga/v1
SINGPAY_CLIENT_ID=
SINGPAY_CLIENT_SECRET=
SINGPAY_WALLET_ID=
# Obligatoire lorsque le portefeuille SingPay de production l'exige
SINGPAY_DISBURSEMENT=
SINGPAY_PHONE_COUNTRY_CODE=241
SINGPAY_TIMEOUT_MS=30000

# MyPVit
MYPVIT_BASE_URL=https://api.mypvit.pro
MYPVIT_MERCHANT_SLUG=
MYPVIT_OPERATION_ACCOUNT_CODE=
MYPVIT_API_PASSWORD=
MYPVIT_RENEW_PATH=
MYPVIT_REST_PATH=
MYPVIT_STATUS_PATH=
MYPVIT_RECEPTION_URL_CODE=
MYPVIT_CALLBACK_URL_CODE=
MYPVIT_OWNER_CHARGE=MERCHANT
MYPVIT_OPERATOR_OWNER_CHARGE=MERCHANT
MYPVIT_TIMEOUT_MS=30000
MOBILE_PAYMENT_PROVIDER=mypvit

# SMTP timeouts: an unavailable mail server must not block payment finalization
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_GREETING_TIMEOUT_MS=5000
SMTP_SOCKET_TIMEOUT_MS=10000

# URL publique à enregistrer comme callback dans le portefeuille SingPay :
# https://votre-domaine.ga/api/paiements/singpay/callback
