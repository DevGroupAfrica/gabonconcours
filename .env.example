# Use backend/.env and frontend/.env for actual configuration

# ========================================
# DOCKER COMPOSE ENVIRONMENT
# ========================================
# Note: Adjust these values in docker-compose.yml or use a .env file with docker-compose

COMPOSE_PROJECT_NAME=gabconcours
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=gabconcours
MYSQL_USER=root
MYSQL_PASSWORD=

DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gabconcours

BACKEND_PORT=3001
FRONTEND_PORT=3000

# ========================================
# For Development
# ========================================
NODE_ENV=development

